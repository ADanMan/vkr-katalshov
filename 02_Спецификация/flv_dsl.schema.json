{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://vkr-katalshov.example/flv_dsl.schema.json",
  "title": "FLV DSL Schema v1",
  "description": "JSON Schema для нормативной модели измерительного процесса (вход FLV-модуля). Применяется к dsl_*.yaml после его парсинга.",
  "type": "object",
  "required": ["meta", "process", "states", "transitions", "violations_catalog"],
  "additionalProperties": false,

  "properties": {
    "$schema": { "type": "string" },

    "meta": {
      "type": "object",
      "required": ["id", "version"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "version": { "type": ["string", "number"] },
        "unit_system": { "type": "string", "enum": ["SI", "imperial"] },
        "date": { "type": "string", "format": "date" },
        "author": { "type": "string" },
        "refs": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },

    "process": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "pattern": "^[a-zA-Z][a-zA-Z0-9_]*$" },
        "description": { "type": "string" }
      }
    },

    "parameters": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": { "type": "string", "enum": ["int", "float", "bool", "string"] },
          "unit": { "type": "string" },
          "min": { "type": ["number", "integer"] },
          "max": { "type": ["number", "integer"] },
          "default": {},
          "description": { "type": "string" }
        }
      }
    },

    "states": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*$" },
          "required": { "type": "boolean", "default": false },
          "description": { "type": "string" }
        },
        "additionalProperties": false
      }
    },

    "transitions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["from", "to"],
        "properties": {
          "id": { "type": "string" },
          "from": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*$" },
          "to": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*$" },
          "guard": { "type": "string" },
          "time": {
            "type": "object",
            "properties": {
              "min": { "type": ["number", "integer"], "minimum": 0 },
              "max": { "type": ["number", "integer"], "minimum": 0 },
              "unit": { "type": "string", "default": "s" }
            },
            "additionalProperties": false
          },
          "description": { "type": "string" }
        },
        "additionalProperties": false
      }
    },

    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind"],
        "properties": {
          "id": { "type": "string" },
          "kind": { "type": "string", "enum": ["sequence", "timing", "predicate", "range"] },
          "must_include": { "type": "array", "items": { "type": "string" } },
          "must_be_in_order": { "type": "boolean" },
          "state": { "type": "string" },
          "min_duration": { "type": ["number", "integer"] },
          "max_duration": { "type": ["number", "integer"] },
          "when": { "type": "string" },
          "condition": { "type": "string" },
          "variable": { "type": "string" },
          "min": { "type": ["number", "integer"] },
          "max": { "type": ["number", "integer", "string"] },
          "unit": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    },

    "violations_catalog": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["severity", "message"],
        "properties": {
          "severity": { "type": "string", "enum": ["critical", "warning", "info"] },
          "message": { "type": "string", "minLength": 1 },
          "related_check": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  }
}
